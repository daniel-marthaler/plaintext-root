<?xml version="1.0" encoding="UTF-8"?>
<faces-config xmlns="https://jakarta.ee/xml/ns/jakartaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-facesconfig_4_0.xsd"
              version="4.0">

    <!-- Register FreyaMenu Component -->
    <component>
        <component-type>org.primefaces.component.FreyaMenu</component-type>
        <component-class>ch.plaintext.boot.plugins.jsf.freya.FreyaMenu</component-class>
    </component>

    <!-- Register FreyaMenuRenderer -->
    <render-kit>
        <renderer>
            <component-family>org.primefaces.component</component-family>
            <renderer-type>org.primefaces.component.FreyaMenuRenderer</renderer-type>
            <renderer-class>ch.plaintext.boot.plugins.jsf.freya.FreyaMenuRenderer</renderer-class>
        </renderer>
    </render-kit>

</faces-config>
